# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Hostname the `database` service uses to reach Postgres.
# Inside Docker this MUST be the compose service name (`postgres`), not `localhost`.
# Only override if you're pointing the database service at an external Postgres.
POSTGRES_HOST=postgres

# Port Postgres listens on inside the Docker network. Postgres in the
# container listens on 5432 by default — do not change unless you also
# override the postgres command to listen on a different port.
POSTGRES_PORT=5432

# Database Service

# Host-side port mapped to Postgres (so you can connect from your host
# machine, e.g. with psql or a GUI client). Has no effect on inter-container
# traffic, which always uses POSTGRES_PORT above.
DB_PORT=5432

# Internal port for the Prisma/Express data API (`database` service).
PRISMA_PORT=4000

# Same value as PRISMA_PORT, exposed to the Vite client build at compile time.
VITE_PRISMA_PORT=4000
