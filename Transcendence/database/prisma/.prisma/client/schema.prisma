// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = ".prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(50)
  email        String   @unique @db.VarChar(100)
  passwordHash String?  @db.Text
  avatarUrl    String?  @db.Text
  createdAt    DateTime @default(now()) @db.Timestamp(6)

  // Relations
  friendshipsAsUser   Friendship[]      @relation("FriendshipUser")
  friendshipsAsFriend Friendship[]      @relation("FriendshipFriend")
  matchPlayers        MatchPlayer[]
  stats               Stat?
  userAchievements    UserAchievement[]

  @@map("users")
}

model Friendship {
  userId    Int
  friendId  Int
  createdAt DateTime @default(now()) @db.Timestamp(6)

  // Relations
  user   User @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendshipFriend", fields: [friendId], references: [id], onDelete: Cascade)

  @@id([userId, friendId])
  @@map("friendships")
}

model Match {
  id         Int       @id @default(autoincrement())
  gameMode   String    @db.VarChar(50)
  maxPlayers Int       @default(4)
  status     String    @default("waiting") @db.VarChar(20)
  createdAt  DateTime  @default(now()) @db.Timestamp(6)
  startedAt  DateTime? @db.Timestamp(6)
  endedAt    DateTime? @db.Timestamp(6)

  // Relations
  matchPlayers MatchPlayer[]

  @@map("matches")
}

model MatchPlayer {
  id       Int      @id @default(autoincrement())
  matchId  Int
  userId   Int
  score    Int      @default(0)
  position Int?
  joinedAt DateTime @default(now()) @db.Timestamp(6)

  // Relations
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@map("match_players")
}

model Stat {
  userId      Int @id
  gamesPlayed Int @default(0)
  wins        Int @default(0)
  losses      Int @default(0)
  elo         Int @default(1000)

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("stats")
}

model Achievement {
  id          Int    @id @default(autoincrement())
  name_id     String @unique @db.VarChar(50)
  name        String @db.VarChar(100)
  description String @db.Text

  // Relations
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userusername       String
  achievementName_id String   @db.VarChar(50)
  unlockedAt         DateTime @default(now()) @db.Timestamp(6)

  // Relations
  user        User        @relation(fields: [userusername], references: [username], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementName_id], references: [name_id], onDelete: Cascade)

  @@id([userusername, achievementName_id])
  @@map("user_achievements")
}
