// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = ".prisma/client"
}

datasource db {
  provider = "postgresql"
}

/// Usuario del sistema. El username es la clave primaria semántica.
model User {
  /// Nombre de usuario único (clave primaria, usado en URLs y relaciones)
  username      String   @id @unique @db.VarChar(50)
  /// Email único del usuario
  email         String   @unique @db.VarChar(100)
  /// Hash de la contraseña (obligatorio)
  passwordHash  String   @db.Text
  /// URL del avatar (opcional)
  avatarUrl     String?  @db.Text
  /// Fecha de creación
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  // Relaciones
  friendshipsAsUser   Friendship[] @relation("FriendshipUser")
  friendshipsAsFriend Friendship[] @relation("FriendshipFriend")
  matchPlayers        MatchPlayer[]
  stats               Stat?
  userAchievements    UserAchievement[]

  @@map("users")
}

/// Relación de amistad entre dos usuarios (no bidireccional).
model Friendship {
  /// Username del usuario que inicia la amistad
  userUsername    String
  /// Username del amigo
  friendUsername  String
  /// Fecha de creación de la amistad
  createdAt       DateTime @default(now()) @db.Timestamp(6)

  // Relaciones
  user   User @relation("FriendshipUser", fields: [userUsername], references: [username], onDelete: Cascade)
  friend User @relation("FriendshipFriend", fields: [friendUsername], references: [username], onDelete: Cascade)

  @@id([userUsername, friendUsername])
  @@index([friendUsername])
  @@map("friendships")
}

/// Partida de juego.
model Match {
  /// Identificador único de la partida
  id         Int      @id @default(autoincrement())
  /// Modo de juego (ej: "Battle Royale")
  gameMode   String   @db.VarChar(50)
  /// Máximo de jugadores
  maxPlayers Int      @default(4)
  /// Estado de la partida (waiting, active, completed)
  status     String   @default("waiting") @db.VarChar(20)
  /// Estado dinámico de la partida (JSON)
  gameState  Json?
  /// Fecha de creación
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  /// Fecha de inicio
  startedAt  DateTime? @db.Timestamp(6)
  /// Fecha de finalización
  endedAt    DateTime? @db.Timestamp(6)

  // Relaciones
  matchPlayers MatchPlayer[]

  @@map("matches")
}

/// Relación de un usuario participando en una partida.
model MatchPlayer {
  /// Identificador único de la relación
  id         Int      @id @default(autoincrement())
  /// ID de la partida
  matchId    Int
  /// Username del jugador
  username   String   @db.VarChar(50)
  /// Puntuación del jugador
  score      Int      @default(0)
  /// Posición final (si aplica)
  position   Int?
  /// Fecha de ingreso a la partida
  joinedAt   DateTime @default(now()) @db.Timestamp(6)

  // Relaciones
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [username], references: [username], onDelete: Cascade)

  @@unique([matchId, username])
  @@index([matchId])
  @@index([username])
  @@map("match_players")
}

/// Estadísticas acumuladas de un usuario.
model Stat {
  /// Username del usuario (PK y FK)
  username     String @id @db.VarChar(50)
  /// Partidas jugadas
  gamesPlayed  Int    @default(0)
  /// Partidas ganadas
  wins         Int    @default(0)
  /// Partidas perdidas
  losses       Int    @default(0)
  /// ELO actual
  elo          Int    @default(1000)

  // Relaciones
  user User @relation(fields: [username], references: [username], onDelete: Cascade)

  @@map("stats")
}

/// Logro disponible en el sistema.
model Achievement {
  /// Identificador único del logro
  id          Int    @id @default(autoincrement())
  /// Nombre semántico único del logro (para relaciones)
  nameId      String @unique @db.VarChar(50)
  /// Nombre visible del logro
  name        String @db.VarChar(100)
  /// Descripción del logro
  description String @db.Text

  // Relaciones
  userAchievements UserAchievement[]

  @@map("achievements")
}

/// Relación de un usuario que ha desbloqueado un logro.
model UserAchievement {
  /// Username del usuario
  username      String  @db.VarChar(50)
  /// Clave semántica del logro
  achievementNameId String  @db.VarChar(50)
  /// Fecha de desbloqueo
  unlockedAt    DateTime @default(now()) @db.Timestamp(6)

  // Relaciones
  user        User        @relation(fields: [username], references: [username], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementNameId], references: [nameId], onDelete: Cascade)

  @@id([username, achievementNameId])
  @@index([achievementNameId])
  @@map("user_achievements")
}